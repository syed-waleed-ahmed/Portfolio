# === Dependencies ===
node_modules/

# === Build output ===
dist/
dist-ssr/
frontend/dist/
backend/dist/

# === Vite cache (anywhere, including stray root .vite/) ===
.vite/
**/.vite/

# === Env / secrets ===
.env
.env.*
backend/.env
frontend/.env
# But DO track .env.example templates — they're checked-in placeholders
!.env.example
!**/.env.example

# === Logs ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# === Editor / IDE ===
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.sw?
*.local

# === Local AI / agent caches ===
.claude/

# === graphify knowledge graph ===
# Track the deliverables (graph.html, graph.json, GRAPH_REPORT.md); ignore the
# regenerable working state so the repo stays clean.
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
.graphify_*
.graphify_python

# === Secrets / keys / certificates (live app — never commit these) ===
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.keystore
id_rsa
id_rsa.*
secrets.json
.secrets/

# === Deployment / platform artifacts ===
.netlify/
.render/
.vercel/
.cache/

