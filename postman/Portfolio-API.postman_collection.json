						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Tester\",\n  \"email\": \"not-an-email\",\n  \"subject\": \"Bad email\",\n  \"message\": \"Email is malformed.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
