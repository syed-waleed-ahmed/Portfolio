{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
		"name": "Portfolio API",
		"description": "Postman collection for the Syed Waleed Ahmed portfolio backend.\n\n**Endpoints covered**\n- `GET /` — root health probe\n- `GET /health` — health check with timestamp\n- `POST /api/contact` — contact form (validation + rate limit + Resend email)\n\n**How to use**\n1. Import this collection and the matching environment file (`Portfolio-API.postman_environment.json`).\n2. Set `baseUrl` to either `http://localhost:5000` (local) or your deployed Render URL.\n3. Run the requests individually, or use **Runner** to execute the full suite.\n\n**Notes**\n- The contact endpoint is rate-limited to **5 requests / 15 min / IP**. The \"Rate limit triggered\" request expects a 429 after the limit is exhausted.\n- Tests use `pm.test()` assertions on status code and response shape; failures will show up in the Runner.\n- Successful contact submissions actually send an email if `RESEND_API_KEY`, `EMAIL_FROM`, and `EMAIL_TO` are set on the backend.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "GET / — root",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('returns ok status', () => {",
									"  const json = pm.response.json();",
									"  pm.expect(json.status).to.eql('ok');",
									"  pm.expect(json.message).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								""
							]
						},
						"description": "Root probe. Returns `{ status: 'ok', message: 'Portfolio backend is running' }`."
					},
					"response": []
				},
				{
					"name": "GET /health",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('returns ok + ISO timestamp', () => {",
									"  const json = pm.response.json();",
									"  pm.expect(json.status).to.eql('ok');",
									"  pm.expect(new Date(json.time).toString()).to.not.eql('Invalid Date');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Health check with current server time. Useful for uptime monitors."
					},
					"response": []
				}
			]
		},
		{
			"name": "Contact",
			"item": [
				{
					"name": "POST /api/contact — happy path",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200, 502, or 503 (mailer dependent)', () => {",
									"  pm.expect([200, 502, 503]).to.include(pm.response.code);",
									"});",
									"if (pm.response.code === 200) {",
									"  pm.test('returns success payload', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.eql(true);",
									"    pm.expect(json.message).to.be.a('string');",
									"  });",
									"} else {",
									"  pm.test('returns mailer error payload (503 not configured / 502 delivery failed)', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.eql(false);",
									"    pm.expect(json.error).to.match(/not configured|delivery failed/i);",
									"  });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Tester\",\n  \"email\": \"tester@example.com\",\n  \"subject\": \"Hello from Postman\",\n  \"message\": \"This is a test message submitted via the Postman collection.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"contact"
							]
						},
						"description": "Submit a valid contact form payload. Returns 200 when the email sends, 503 if the mailer is unconfigured (missing Resend env vars), or 502 if Resend rejects the send."
					},
					"response": []
				},
