				{
					"name": "POST /api/contact — field too long",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 400', () => pm.response.to.have.status(400));",
									"pm.test('error mentions max length', () => {",
									"  const json = pm.response.json();",
									"  pm.expect(json.success).to.eql(false);",
									"  pm.expect(json.error).to.match(/too long/i);",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Generate a 101-char name (max is 100)",
									"pm.variables.set('oversizedName', 'a'.repeat(101));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"{{oversizedName}}\",\n  \"email\": \"tester@example.com\",\n  \"subject\": \"Long name\",\n  \"message\": \"Name exceeds the 100-char cap.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"contact"
							]
						},
						"description": "Sends a 101-character name (max is 100). Backend should reject with 400 'Field \"name\" is too long'."
					},
					"response": []
				},
