					},
					"response": []
				},
				{
					"name": "POST /api/contact — payload too large",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 413', () => pm.response.to.have.status(413));",
									"pm.test('returns payload-too-large error', () => {",
									"  const json = pm.response.json();",
									"  pm.expect(json.success).to.eql(false);",
									"  pm.expect(json.error).to.match(/payload too large/i);",
									"});",
									"// express.json() is registered before the router, so the body is",
									"// rejected ahead of the rate limiter - this request costs no quota.",
									"pm.test('did not consume rate-limit quota', () => {",
									"  pm.expect(pm.response.headers.has('RateLimit-Remaining')).to.eql(false);",
									"});"
								]
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Body cap is express.json({ limit: '16kb' }). Overshoot it clearly.",
									"pm.variables.set('oversizedMessage', 'a'.repeat(20000));"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Postman Tester\",\n  \"email\": \"tester@example.com\",\n  \"subject\": \"Oversized body\",\n  \"message\": \"{{oversizedMessage}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"contact"
							]
						},
						"description": "Sends a ~20 KB JSON body against the 16 KB cap (express.json({ limit: '16kb' })). Backend should reject with 413 'Payload too large.' before the router runs, so it does not consume rate-limit quota. Distinct from 'field too long', which is the 100-char name validation and returns 400."
					},
					"response": []
				},
				{
					"name": "POST /api/contact — honeypot tripped",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Answers exactly like a real send, on purpose: a bot that could tell",
									"// rejection from success would just retry without the field.",
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('looks like a normal success', () => {",
									"  const json = pm.response.json();",
									"  pm.expect(json.success).to.eql(true);",
									"});",
									"// Nothing was actually sent. Against a configured backend a real send",
									"// returns an `id` from Resend; a dropped one has none.",
									"pm.test('no mail id — message was dropped', () => {",
									"  pm.expect(pm.response.json().id).to.be.undefined;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Spam Bot\",\n  \"email\": \"bot@example.com\",\n  \"subject\": \"Buy things\",\n  \"message\": \"Spam body.\",\n  \"website\": \"http://spam.example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"contact"
							]
						},
						"description": "Fills the hidden `website` honeypot field. The backend drops the submission without sending, but answers with the same 200 a real send gets so a bot cannot detect the trap. Safe to run against production - no email is sent. Note it DOES consume rate-limit quota, since the check runs inside the router, after the limiter."
					},
					"response": []
				},
				{
					"name": "POST /api/contact — rate limit triggered",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Run this request 6+ times in a row (Runner) to trigger the limiter.",
									"// First 5 should succeed/validate; 6th should 429.",
									"pm.test('rate-limit response shape on 429', () => {",
									"  if (pm.response.code === 429) {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.eql(false);",
									"    pm.expect(json.error).to.match(/too many requests/i);",
									"    pm.expect(pm.response.headers.get('RateLimit-Limit')).to.not.be.null;",
									"  } else {",
									"    pm.test.skip && pm.test.skip('not yet rate-limited');",
									"  }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Rate Limit Tester\",\n  \"email\": \"ratelimit@example.com\",\n  \"subject\": \"Burst\",\n  \"message\": \"Fire this six times in a row using the Runner to trigger 429.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/contact",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"contact"
							]
						},
						"description": "To trigger the limiter, open Runner, select this request, set Iterations = 6+, and run. The 6th call should return 429 with `RateLimit-*` headers."
					},
					"response": []
				}
			]
		},
