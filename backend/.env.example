# Copy this file to backend/.env and fill in real values.
# NEVER commit the resulting .env file (already in .gitignore).

# Port the backend listens on (Render sets this automatically)
PORT=5000

# Mark as production in deployed environments to suppress error detail leaks
NODE_ENV=development

# Resend (https://resend.com) — transactional email provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From: must be a verified domain or onboarding@resend.dev for testing
EMAIL_FROM=onboarding@resend.dev

# To: where contact-form messages should land
EMAIL_TO=your-email@example.com
